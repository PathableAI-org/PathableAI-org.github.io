---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { CATEGORIES } from '../../consts';
import { getArticlesByCategory } from '../../lib/articles';

export const getStaticPaths = (() => {
  return CATEGORIES.map((category) => ({
    params: { category: category.id },
    props: { category },
  }));
}) satisfies GetStaticPaths;

const { category } = Astro.props;
const articles = await getArticlesByCategory(category.id);
---

<BaseLayout title={category.label} description={category.blurb}>
  <header class="page-head">
    <p class="eyebrow">Engineering at PathAble</p>
    <h1>{category.label}</h1>
    <p class="muted lede">{category.blurb}</p>
  </header>

  {
    articles.length > 0 ? (
      <ul class="card-grid">
        {articles.map((article) => (
          <ArticleCard article={article} showCategory={false} />
        ))}
      </ul>
    ) : (
      <p class="muted">Content forthcoming.</p>
    )
  }
</BaseLayout>

<style>
  .page-head {
    margin-bottom: var(--space-12);
  }
  .lede {
    font-size: 1.2rem;
    max-width: var(--content-width);
  }
</style>
