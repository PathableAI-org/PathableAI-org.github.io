---
import BaseLayout from '../layouts/BaseLayout.astro';
import { CATEGORIES, SITE_TAGLINE } from '../consts';
---

<BaseLayout>
  <section class="hero">
    <p class="eyebrow">Engineering at PathAble</p>
    <h1>{SITE_TAGLINE}</h1>
    <p class="lede muted">
      Field notes, architecture notes, practice guides, and open-source work
      from the team building human-centered, AI-enhanced software for the
      disability employment community.
    </p>
    <p class="forthcoming">Content forthcoming.</p>
  </section>

  <section aria-labelledby="explore-heading" class="section">
    <h2 id="explore-heading">Explore</h2>
    <ul class="card-grid">
      {
        CATEGORIES.map((category) => (
          <li class="card">
            <h3>
              <a href={`/${category.id}/`}>{category.label}</a>
            </h3>
            <p class="muted">{category.blurb}</p>
          </li>
        ))
      }
    </ul>
  </section>

  <section aria-labelledby="coming-soon-heading" class="section">
    <h2 id="coming-soon-heading">Coming soon</h2>
    <p class="muted">
      We are preparing our first articles. Check back for field notes,
      architecture decisions, practice guides, and open-source documentation.
    </p>
  </section>
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-8) var(--space-12);
    max-width: var(--content-width);
  }
  .lede {
    font-size: 1.25rem;
  }
  .forthcoming {
    display: inline-block;
    margin-top: var(--space-6);
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-subheading);
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-highlight);
    border-radius: var(--radius);
  }
  .section {
    margin-top: var(--space-16);
  }
  .section h2 {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
  }
</style>
