---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getTagMap, tagUrl } from '../../lib/articles';

export const getStaticPaths = (async () => {
  const tagMap = await getTagMap();
  return [...tagMap.entries()].map(([tag, articles]) => ({
    // Slugify the tag so the param matches the generated tag URLs.
    params: { tag: tagUrl(tag).split('/').filter(Boolean).pop() },
    props: { tag, articles },
  }));
}) satisfies GetStaticPaths;

const { tag, articles } = Astro.props;
---

<BaseLayout title={`#${tag}`} description={`Articles tagged ${tag}.`}>
  <header class="page-head">
    <p class="eyebrow">Tag</p>
    <h1>#{tag}</h1>
    <p class="muted">
      <a href="/tags/">All tags</a>
    </p>
  </header>

  <ul class="card-grid">
    {articles.map((article) => <ArticleCard article={article} />)}
  </ul>
</BaseLayout>

<style>
  .page-head {
    margin-bottom: var(--space-8);
  }
</style>
