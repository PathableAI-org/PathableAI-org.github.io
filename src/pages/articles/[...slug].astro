---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import MaturityBadge from '../../components/MaturityBadge.astro';
import { getCategory } from '../../consts';
import { tagUrl, formatAuthors, type Article } from '../../lib/articles';
import { getPublishedArticles } from '../../lib/articles';

export const getStaticPaths = (async () => {
  const articles = await getPublishedArticles();
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}) satisfies GetStaticPaths;

interface Props {
  article: Article;
}

const { article } = Astro.props;
const { data } = article;
const category = getCategory(data.category);
const { Content } = await render(article);
const socialImage = data.socialImage?.src ?? data.heroImage?.src;
const canonicalOverride = data.canonicalUrl;
---

<BaseLayout
  title={data.title}
  description={data.description}
  type="article"
  image={socialImage}
  canonicalUrl={canonicalOverride}
>
  <article>
    <header class="article-head">
      <p class="eyebrow">
        {category && <a href={`/${category.id}/`}>{category.label}</a>}
      </p>
      <h1>{data.title}</h1>
      <p class="lede muted">{data.description}</p>
      <div class="byline">
        <MaturityBadge level={data.maturity} />
        <span class="muted">
          By {formatAuthors(data.authors)} &middot;{' '}
          <FormattedDate date={data.pubDate} />
          {
            data.updatedDate && (
              <>
                {' '}
                &middot; Updated <FormattedDate date={data.updatedDate} />
              </>
            )
          }
          {data.reviewedBy && <> &middot; Reviewed by {data.reviewedBy}</>}
        </span>
      </div>
      {
        data.heroImage && (
          <img
            class="hero-image"
            src={data.heroImage.src}
            width={data.heroImage.width}
            height={data.heroImage.height}
            alt={data.heroAlt ?? ''}
          />
        )
      }
    </header>

    <div class="prose">
      <Content />
    </div>

    {
      data.tags.length > 0 && (
        <footer class="article-tags">
          <h2 class="visually-hidden">Tags</h2>
          <ul class="tag-list">
            {data.tags.map((tag) => (
              <li>
                <a class="tag" href={tagUrl(tag)}>
                  #{tag}
                </a>
              </li>
            ))}
          </ul>
        </footer>
      )
    }
  </article>
</BaseLayout>

<style>
  .article-head {
    max-width: var(--content-width);
    margin-bottom: var(--space-8);
  }
  .lede {
    font-size: 1.25rem;
  }
  .byline {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }
  .hero-image {
    margin-top: var(--space-6);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }
  .article-tags {
    margin-top: var(--space-12);
    border-top: 1px solid var(--color-border);
    padding-top: var(--space-6);
  }
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
