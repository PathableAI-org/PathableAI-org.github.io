---
import { SITE_TITLE, PARENT_BRAND, PARENT_SITE } from '../consts';

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <p>
      <strong>{SITE_TITLE}</strong> is the engineering publication of{' '}
      <a href={PARENT_SITE} rel="noopener">{PARENT_BRAND}</a>.
    </p>
    <nav aria-label="Footer">
      <ul>
        <li><a href="/about/">About</a></li>
        <li><a href="/rss.xml">RSS</a></li>
        <li><a href={PARENT_SITE} rel="noopener">PathAble.com</a></li>
      </ul>
    </nav>
    <p class="muted small">
      &copy; {year}
      {PARENT_BRAND}.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-16);
  }
  .footer-inner {
    padding-block: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  nav ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  nav a {
    font-weight: 600;
  }
  .small {
    font-size: 0.85rem;
  }
</style>
